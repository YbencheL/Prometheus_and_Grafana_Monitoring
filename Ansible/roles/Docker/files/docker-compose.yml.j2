services:

  prometheus:
    image: yass555/prometheus:1.0
    container_name: prometheus
    ports: 
      - 9090:9090
    expose:
      - 9090
    networks:
      monitoring:
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9090/-/healthy"]
      interval: 30s
      timeout: 30s
      retries: 5
      start_period: 30s
    # volumes:
    #   - prometheus:/etc/prometheus
    restart: unless-stopped

  alertmanager:
    image: yass555/alertmanager:1.0
    container_name: alertmanager
    ports: 
      - 9093:9093
    expose:
      - 9093
    networks:
      monitoring:
    healthcheck:
      test: ["CMD", "curl", "-i", "http://localhost:9093/-/healthy"]
      interval: 30s
      timeout: 30s
      retries: 5
      start_period: 30s
    restart: unless-stopped

  node-exporter:
    image: yass555/node-exporter:1.0
    container_name: node-exporter
    ports: 
      - 9100:9100
    expose:
      - 9100
    networks:
      monitoring:
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9100"]
      interval: 30s
      timeout: 30s
      retries: 5
      start_period: 30s
    volumes:
      - /:/host:ro,rslave
    restart: unless-stopped
    
  grafana:
    image: yass555/grafana:1.0
    container_name: grafana
    ports:
      - 3000:3000
    expose:
      - 3000
    networks:
      monitoring:
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 30s
      retries: 5
      start_period: 30s
    restart: unless-stopped
    
  nginx:
    image: yass555/nginx:1.0
    container_name: nginx
    ports:
      - 80:80
      - 443:443
    networks:
      monitoring:
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost"]
      interval: 30s
      timeout: 30s
      retries: 5
      start_period: 30s
    restart: unless-stopped
    
  node-serv:
    image: yass555/node-serv:1.0
    container_name: node-serv
    ports:
      - 8000:8000
    networks:
      monitoring:
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000"]
      interval: 30s
      timeout: 30s
      retries: 5
      start_period: 30s
    restart: unless-stopped
    
networks:
  monitoring:
